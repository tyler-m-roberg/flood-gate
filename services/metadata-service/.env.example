# ── FloodGate Metadata Service — environment variables ────────────────────────
# Copy to .env and adjust for your environment.
# .env is gitignored; never commit secrets.

# ── Service ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the browser SPA
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Keycloak ───────────────────────────────────────────────────────────────────
# Base URL of your Keycloak instance (no trailing slash)
KEYCLOAK_URL=http://localhost:8080

# Realm name (must match the realm configured in Keycloak admin)
KEYCLOAK_REALM=floodgate

# This service's Keycloak client ID
KEYCLOAK_CLIENT_ID=floodgate-metadata

# Client secret — required if the client is "confidential" in Keycloak.
# Leave blank for public clients.
KEYCLOAK_CLIENT_SECRET=

# ── JWT validation ─────────────────────────────────────────────────────────────
# Audience claim the token must contain.
# Defaults to KEYCLOAK_CLIENT_ID if left blank.
# Set to "account" if your realm tokens don't include resource audience.
JWT_AUDIENCE=floodgate-metadata

# Comma-separated list of accepted signing algorithms
JWT_ALGORITHMS=RS256

# Seconds to cache JWKS before re-fetching (handles key rotation gracefully)
JWKS_CACHE_TTL=300

# Set to false only in local development if Keycloak isn't running
JWT_VERIFY_AUDIENCE=true

# ── BFF session cookie ─────────────────────────────────────────────────────────
# Enable cookie-based auth for the React BFF pattern
COOKIE_AUTH_ENABLED=true
SESSION_COOKIE_NAME=session_token

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite for local dev; use asyncpg for production PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./floodgate_meta.db

# Use in-memory mock data (no database required)
USE_MOCK_DATA=true

# ── Production PostgreSQL example ─────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://floodgate:secret@postgres:5432/floodgate_meta
# USE_MOCK_DATA=false
