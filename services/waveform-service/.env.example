# FloodGate Waveform Service — environment variable reference
# Copy to .env for local development (never commit .env itself).

# ── Service ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8002

# ── Keycloak / OIDC ────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=floodgate
KEYCLOAK_CLIENT_ID=floodgate-waveform

# Set false during initial dev before Keycloak realm is configured
JWT_VERIFY_AUDIENCE=true

# BFF session-cookie auth (set true when using nginx BFF proxy)
COOKIE_AUTH_ENABLED=true
SESSION_COOKIE_NAME=session_token

# JWKS cache lifetime in seconds (handles key rotation)
JWKS_CACHE_TTL_SECONDS=300

# ── MinIO / object storage ─────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_TLS=false
MINIO_BUCKET=floodgate-waveforms
